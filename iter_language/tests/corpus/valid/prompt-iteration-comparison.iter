queue memory

workspace clone {
  base = "."
  excludes = []
  preserve_mtime = true
  apply_back { mode = sync }}

agent claude {
  mode = print
  command = "claude"
}

runner {
  agent = claude
  workspace = clone
  queue = memory
  continue_on_error = true
  behavior = wait
  prompt {
    iteration.count == 1 => "first run"
    iteration.consecutive_failures >= 3 => "three failures in a row"
    iteration.previous_exit_code != 0 => "previous turn errored exit={{iteration.previous_exit_code}}"
    _ => "regular tick n={{iteration.count}}"
  }
}
