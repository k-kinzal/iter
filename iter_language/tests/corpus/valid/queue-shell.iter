queue shell {
  enqueue = "redis-cli -u $REDIS_URL ZADD myq $ITER_SIGNAL_PRIORITY -"
  dequeue = "./scripts/poll-myq.sh"
  close   = "redis-cli -u $REDIS_URL DEL myq"
  interpreter = "bash -c"
  enqueue_timeout = 30s
}

workspace local {
  base = "."
}

agent claude {
  mode = print
  command = "claude"
}

runner {
  agent = claude
  workspace = local
  queue = shell
  continue_on_error = false
  behavior = wait
  prompt = "do the thing"
}
