queue servicebus {
  fully_qualified_namespace = "iter-bus.servicebus.windows.net"
  entity_kind               = "subscription"
  topic_name                = "signals"
  subscription_name         = "iter-runner"
  transport                 = "amqp_websockets"
  custom_endpoint_address   = "iter-bus-private.servicebus.windows.net"
  connection_idle_timeout   = 60s
  identifier                = "iter-runner-1"
  authority_host            = "https://login.microsoftonline.com"

  web_proxy {
    url      = "http://proxy.corp:3128"
    username = "iter"
    password = env("PROXY_PASSWORD")
  }

  auth {
    kind          = "aad_client_secret"
    tenant_id     = "00000000-0000-0000-0000-000000000000"
    client_id     = "00000000-0000-0000-0000-000000000000"
    client_secret = env("AZURE_CLIENT_SECRET")
  }

  sender {
    message_id            = from_metadata("signal_id")
    correlation_id        = from_metadata("workspace")
    content_type          = "application/json"
    subject               = "iter-signal"
    reply_to              = "iter-replies"
    reply_to_session_id   = "iter-session"
    time_to_live          = 3600s
    scheduled_enqueue_time = "2026-12-31T23:59:59Z"
    partition_key_strategy = from_metadata("workspace")
    session_id_strategy    = from_metadata("workspace")
    application_properties {
      source = "iter"
    }
    batch_size      = 50
    batch_max_bytes = 262144
    batch_linger    = 1s
    retry {
      mode = "exponential"
      max_attempts = 5
    }
  }

  receiver {
    receive_mode                       = "peek_lock"
    prefetch_count                     = 50
    sub_queue                          = "none"
    identifier                         = "iter-receiver-1"
    max_wait_time                      = 20s
    max_messages                       = 10
    max_auto_lock_renewal_duration     = 300s
    on_handler_error                   = "dead_letter"
    dead_letter_reason_template        = "{{error.kind}}"
    dead_letter_description_template   = "{{error.message}}"
    retry {
      mode = "exponential"
      max_attempts = 5
    }
  }

  session {
    mode                 = "accept_next"
    session_idle_timeout = 60s
  }

  retry {
    mode         = "exponential"
    max_attempts = 5
  }

  dlq {
    kind = "native"
  }
}

workspace local {
  base = "."
}

agent claude {
  mode = print
  command = "claude"
}

runner {
  agent = claude
  workspace = local
  queue = servicebus
  continue_on_error = false
  behavior = wait
  prompt = "do the thing"
}
