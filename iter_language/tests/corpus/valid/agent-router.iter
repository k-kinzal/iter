queue memory

workspace local {
  base = "."
}

agent router {
  strategy = fallback

  primary {
    kind    = claude
    mode    = print
    command = "claude"
  }

  secondary {
    kind    = codex
    mode    = print
    command = "codex"
  }
}

runner {
  agent = router
  workspace = local
  queue = memory
  continue_on_error = false
  behavior = wait
  prompt = "Router fallback test."
}
