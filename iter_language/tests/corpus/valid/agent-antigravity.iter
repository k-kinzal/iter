queue memory

workspace local {
  base = "."
}

agent antigravity {
  mode            = print
  command         = "agy"
  args            = ["--print-timeout", "600"]
  conversation_id = "my-session"
}

runner {
  agent = antigravity
  workspace = local
  queue = memory
  continue_on_error = false
  behavior = wait
  prompt = "Antigravity test."
}
