queue memory

workspace local {
  base = "."
}

agent generic {
  command = ["python", "./agent.py"]
  env {
    API_KEY = "sk-test"
    DEBUG   = "1"
  }
}

runner {
  agent = generic
  workspace = local
  queue = memory
  continue_on_error = false
  behavior = wait
  prompt = "Generic env test."
}
