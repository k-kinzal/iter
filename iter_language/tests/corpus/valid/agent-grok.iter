queue memory

workspace local {
  base = "."
}

agent grok {
  command         = "grok"
  args            = ["--output-format", "json"]
  session_id_file = ".iter/session-id"
}

runner {
  agent = grok
  workspace = local
  queue = memory
  continue_on_error = false
  behavior = wait
  prompt = "Grok test."
}
