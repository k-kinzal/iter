queue pubsub {
  project          = "my-gcp-project"
  topic            = "iter-signals"
  subscription     = "iter-runner-ordered"
  endpoint         = "us-east1-pubsub.googleapis.com:443"
  user_agent       = "iter/1.0"
  connect_timeout  = 10s
  request_timeout  = 30s
  quota_project    = "my-billing-project"
  scopes           = ["https://www.googleapis.com/auth/pubsub"]

  keepalive {
    time = 60s
    timeout = 20s
    permit_without_stream = true
  }

  credentials {
    kind = "service_account_inline"
    json = env("GCP_SERVICE_ACCOUNT_JSON")
  }

  publisher {
    delay_threshold = 10
    count_threshold = 200
    byte_threshold = 1048576
    max_outstanding_messages = 1000
    max_outstanding_bytes = 100000000
    limit_exceeded_behavior = "block"
    workers = 4
    request_timeout = 30s
    enable_compression = true
    compression_bytes_threshold = 240
    attributes {
      source = "iter"
    }
    ordering_key_strategy = from_metadata("workspace")
    retry {
      mode = "exponential"
      max_attempts = 5
    }
  }

  subscriber {
    pull_mode = "streaming"
    stream_ack_deadline_seconds = 120
    max_outstanding_messages = 100
    max_outstanding_bytes = 100000000
    min_duration_per_lease_extension = 30s
    max_duration_per_lease_extension = 600s
    ping_interval = 30s
    retry {
      mode = "exponential"
      max_attempts = 5
      retryable_codes = ["UNAVAILABLE", "DEADLINE_EXCEEDED"]
    }
  }

  initial_seek {
    kind = "timestamp"
    timestamp = "2026-01-01T00:00:00Z"
  }

  dlq {
    kind = "native"
  }
}

workspace local {
  base = "."
}

agent claude {
  mode = print
  command = "claude"
}

runner {
  agent = claude
  workspace = local
  queue = pubsub
  continue_on_error = false
  behavior = wait
  prompt = "do the thing"
}
