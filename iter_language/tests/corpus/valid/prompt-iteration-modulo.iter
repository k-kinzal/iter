queue memory

workspace clone {
  base = "."
  excludes = []
  preserve_mtime = true
  apply_back { mode = sync }}

agent claude {
  mode = print
  command = "claude"
}

runner {
  continue_on_error = true
  behavior = wait
}

prompt when iteration.count % 10 == 0 "every-tenth tick n={{iteration.count}}"
prompt "tick n={{iteration.count}}"
