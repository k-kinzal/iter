queue memory

workspace clone {
  base = "."
  excludes = []
  preserve_mtime = true
  apply_back { mode = sync }}

agent claude {
  mode = print
  command = "claude"
}

runner {
  agent = claude
  workspace = clone
  queue = memory
  continue_on_error = true
  behavior = wait
  prompt {
    iteration.count % 10 == 0 => "every-tenth tick n={{iteration.count}}"
    _ => "tick n={{iteration.count}}"
  }
}
